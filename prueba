<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Los Aromos Kitchen y Sushi</title>
<style>
:root{
--bg:#000;
--surface:#111;
--accent:#e10600;
--text:#fff;
--muted:#bcbcbc;
}

*{box-sizing:border-box;}

body{
margin:0;
font-family:Arial, sans-serif;
background:var(--bg);
color:var(--text);
padding-bottom:110px;
}

header{
background:var(--surface);
padding:15px;
text-align:center;
font-size:22px;
font-weight:bold;
color:var(--accent);
position:sticky;
top:0;
z-index:10;
}

.container{
padding:15px;
max-width:640px;
margin:0 auto;
}

h3{margin-bottom:8px;}

.product{
background:var(--surface);
border-radius:10px;
padding:15px;
margin-bottom:15px;
border:1px solid #222;
}

.product p{
margin-top:0;
color:var(--muted);
}

button{
background:var(--accent);
color:var(--text);
border:none;
padding:10px;
border-radius:5px;
cursor:pointer;
font-weight:bold;
width:100%;
}

button:hover{opacity:0.86;}
button:disabled{opacity:0.5;cursor:not-allowed;}

.secondary{background:#2b2b2b;margin-top:10px;}

.cart{
position:fixed;
bottom:0;
left:0;
right:0;
background:var(--surface);
padding:12px;
border-top:2px solid var(--accent);
}

input, select{
width:100%;
padding:8px;
margin-top:5px;
margin-bottom:10px;
border-radius:5px;
border:none;
}

.admin{
display:none;
background:var(--surface);
padding:15px;
margin-top:20px;
border-radius:10px;
}

.delivery{margin:10px 0;}

.cart-items{
background:var(--surface);
border:1px solid #222;
border-radius:10px;
padding:10px;
margin-bottom:16px;
}

.cart-items ul{
padding-left:18px;
margin:8px 0;
}

.empty{
color:var(--muted);
font-style:italic;
}

small{color:var(--muted);}
</style>
</head>
<body>

<header>
Los Aromos Kitchen y Sushi
</header>

<div class="container">

<h3>🍣 Sushi</h3>
<div class="product">
<p>Promo 30 piezas - $12.000</p>
<button onclick="addToCart('Promo 30 piezas',12000)">Agregar</button>
</div>

<h3>🍟 Papas Fritas</h3>
<div class="product">
<p>Papas grandes - $4.000</p>
<button onclick="addToCart('Papas grandes',4000)">Agregar</button>
</div>

<h3>🥪 Sandwich</h3>
<div class="product">
<p>Sandwich Churrasco - $6.000</p>
<button onclick="addToCart('Sandwich Churrasco',6000)">Agregar</button>
</div>

<div class="cart-items">
<strong>Detalle del pedido</strong>
<ul id="cartItems"></ul>
<div id="emptyCart" class="empty">Aún no agregas productos.</div>
<small>Subtotal: $<span id="subtotal">0</span></small>
</div>

<div class="delivery">
<label>
<input type="checkbox" id="deliveryCheck"> Envío a domicilio (+$2000)
</label>
</div>

<h3>Datos del Cliente</h3>
<input type="text" id="name" placeholder="Nombre">
<input type="text" id="address" placeholder="Dirección">
<select id="payment">
<option value="Efectivo">Efectivo</option>
<option value="Transferencia">Transferencia</option>
</select>

<button id="sendOrderBtn" onclick="sendOrder()">Finalizar Pedido por WhatsApp</button>
<button class="secondary" onclick="clearCart()">Vaciar carrito</button>
<button class="secondary" onclick="showAdmin()">Panel Administrador</button>

<div class="admin" id="adminPanel">
<h3>Administrador</h3>
<input type="password" id="adminPass" placeholder="Contraseña">
<button onclick="loginAdmin()">Entrar</button>
<div id="adminContent" style="display:none;">
<p>Ventas totales: $<span id="totalSales">0</span></p>
<button onclick="resetSales()">Reiniciar Ventas</button>
</div>
</div>

</div>

<div class="cart">
Carrito: $<span id="total">0</span>
</div>

<script>
const DELIVERY_PRICE = 2000;
const cart = [];
let totalSales = parseInt(localStorage.getItem("sales") || "0", 10);

const totalElement = document.getElementById("total");
const subtotalElement = document.getElementById("subtotal");
const cartItemsElement = document.getElementById("cartItems");
const emptyCartElement = document.getElementById("emptyCart");
const totalSalesElement = document.getElementById("totalSales");
const deliveryCheckElement = document.getElementById("deliveryCheck");
const sendOrderBtnElement = document.getElementById("sendOrderBtn");

totalSalesElement.innerText = totalSales;
updateOrderState();

function calculateSubtotal(){
return cart.reduce((acc, item) => acc + item.price, 0);
}

function calculateTotal(){
return calculateSubtotal() + (deliveryCheckElement.checked ? DELIVERY_PRICE : 0);
}

function formatPrice(value){
return value.toLocaleString("es-CL");
}

function renderCartItems(){
cartItemsElement.innerHTML = "";
if (!cart.length){
emptyCartElement.style.display = "block";
return;
}

emptyCartElement.style.display = "none";
cart.forEach((item, index) => {
const li = document.createElement("li");
li.innerText = `${item.name} - $${formatPrice(item.price)}`;
const removeBtn = document.createElement("button");
removeBtn.className = "secondary";
removeBtn.style.marginTop = "6px";
removeBtn.innerText = "Quitar";
removeBtn.onclick = () => removeItem(index);
li.appendChild(removeBtn);
cartItemsElement.appendChild(li);
});
}

function updateOrderState(){
const subtotal = calculateSubtotal();
const total = calculateTotal();
subtotalElement.innerText = formatPrice(subtotal);
totalElement.innerText = formatPrice(total);
renderCartItems();
sendOrderBtnElement.disabled = cart.length === 0;
}

function addToCart(name, price){
cart.push({ name, price });
updateOrderState();
}

function removeItem(index){
cart.splice(index, 1);
updateOrderState();
}

function clearCart(){
cart.length = 0;
updateOrderState();
}

deliveryCheckElement.addEventListener("change", updateOrderState);

function sendOrder(){
const name = document.getElementById("name").value.trim();
const address = document.getElementById("address").value.trim();
const payment = document.getElementById("payment").value;
const delivery = deliveryCheckElement.checked;
const total = calculateTotal();

if (!cart.length){
alert("Debes agregar al menos un producto.");
return;
}
if (!name || !address){
alert("Por favor completa nombre y dirección.");
return;
}

let message = "Pedido Los Aromos Kitchen y Sushi\n";
cart.forEach(item => {
message += `${item.name} - $${formatPrice(item.price)}\n`;
});
if (delivery){
message += `Delivery: $${formatPrice(DELIVERY_PRICE)}\n`;
}
message += `Total: $${formatPrice(total)}\n`;
message += `Nombre: ${name}\n`;
message += `Dirección: ${address}\n`;
message += `Pago: ${payment}`;

totalSales += total;
localStorage.setItem("sales", totalSales.toString());
totalSalesElement.innerText = formatPrice(totalSales);

window.open(`https://wa.me/56979553144?text=${encodeURIComponent(message)}`, "_blank");
clearCart();
}

function showAdmin(){
const panel = document.getElementById("adminPanel");
panel.style.display = panel.style.display === "block" ? "none" : "block";
}

function loginAdmin(){
const pass = document.getElementById("adminPass").value;
if(pass === "1234"){
document.getElementById("adminContent").style.display = "block";
alert("Bienvenido Administrador");
}else{
alert("Contraseña incorrecta");
}
}

function resetSales(){
totalSales = 0;
localStorage.setItem("sales", "0");
totalSalesElement.innerText = "0";
}
</script>

</body>
</html>
